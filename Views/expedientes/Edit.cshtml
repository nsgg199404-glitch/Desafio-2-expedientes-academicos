@model ExpedientesAcademicos.Models.expediente

@{
    ViewData["Title"] = "Editar Expediente";
}

<h1>Editar</h1>

<h4>expediente</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Editar">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="expedienteId" />
            <div class="form-group">
                <label asp-for="alumnoId" class="control-label"></label>
                <select asp-for="alumnoId" class="form-control" asp-items="ViewBag.alumnoId"></select>
                <span asp-validation-for="alumnoId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="materiaId" class="control-label"></label>
                <select asp-for="materiaId" class="form-control" asp-items="ViewBag.materiaId"></select>
                <span asp-validation-for="materiaId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NotaFinal" class="control-label"></label>
                <input asp-for="NotaFinal" class="form-control" />
                <span asp-validation-for="NotaFinal" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Observaciones" class="control-label"></label>
                <input asp-for="Observaciones" class="form-control" />
                <span asp-validation-for="Observaciones" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="Enviar" value="Guardar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Regresar a lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
