@model ExpedientesAcademicos.Models.Expediente

@{
    ViewData["Title"] = "Delete";
}

    <h1>Eliminar</h1>

    <h3>¿Seguro que deseas eliminar este expediente?</h3>

<div>
     <hr />

    <dl class="row">

         <dt class="col-sm-2">
            Alumno
         </dt>

         <dd class="col-sm-10">
            @Model.Alumno.Nombre @Model.Alumno.Apellido
         </dd>

         <dt class="col-sm-2">
            Materia
         </dt>

         <dd class="col-sm-10">
            @Model.Materia.NombreMateria
         </dd>

         <dt class="col-sm-2">
            Nota Final
         </dt>

         <dd class="col-sm-10">
            @Model.NotaFinal
         </dd>

         <dt class="col-sm-2">
            Observaciones
         </dt>

         <dd class="col-sm-10">
            @Model.Observaciones
         </dd>

    </dl>

        <form asp-controller="Expedientes" asp-action="Delete" method="post">
            <input type="hidden" asp-for="ExpedienteId" />
            <input type="submit" value="Eliminar" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary">Regresar a lista</a>
        </form>

</div>
