@model ExpedientesAcademicos.Models.Expediente

@{
    ViewData["Title"] = "Details";
}

<h1>Ver</h1>

<div>
    <h4>expediente</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Alumno)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Alumno.Nombre)
        </dd>
        <dt class = "col-sm-2">
