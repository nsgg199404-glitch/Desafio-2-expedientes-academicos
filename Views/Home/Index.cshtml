<div class="text-center">
   
    <h1 class="display-4">**********COLEGIO SAN JOSE**********  Sistema de Expedientes Académicos</h1>
    <p class="lead">Gestión de Alumnos, Materias y Calificaciones</p>
</div>

<div class="row mt-5">
    <div class="col-md-4">
        <div class="card shadow text-center">
            <div class="card-body">
                <h5 class="card-title">Alumnos</h5>
                <p class="card-text">Administrar Estudiantes</p>
                <a asp-controller="Alumnos" asp-action="Index" class="btn btn-primary">Ir a Alumnos</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow text-center">
            <div class="card-body">
                <h5 class="card-title">Materias</h5>
                <p class="card-text">Gestionar Materias</p>
                <a asp-controller="Materias" asp-action="Index" class="btn btn-success">Ir a Materias</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow text-center">
            <div class="card-body">
                <h5 class="card-title">Expedientes</h5>
                <p class="card-text">Ver Calificaciones</p>
                <a asp-controller="Expedientes" asp-action="Index" class="btn btn-warning">Ir a Expedientes</a>
            </div>
        </div>
    </div>
</div>

<div class="text-center mt-5">
    <a asp-controller="Expedientes" asp-action="Promedios" class="btn btn-dark">
        Ver Promedios y Gráfica
    </a>
</div>