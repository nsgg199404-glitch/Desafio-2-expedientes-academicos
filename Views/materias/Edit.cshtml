@model ExpedientesAcademicos.Models.Materia

@{
    ViewData["Title"] = "Editar";
}

<h1>Editar</h1>

<h4>Materia</h4>
<hr />

<div class="row">
    <div class="col-md-4">

        <form asp-controller="Materias" asp-action="Edit" asp-route-id="@Model.MateriaId" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="MateriaId" />

            <div class="form-group">
                <label asp-for="NombreMateria" class="control-label"></label>
                <input asp-for="NombreMateria" class="form-control" />
                <span asp-validation-for="NombreMateria" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Docente" class="control-label"></label>
                <input asp-for="Docente" class="form-control" />
                <span asp-validation-for="Docente" class="text-danger"></span>
            </div>

            <br />

            <div class="form-group">
                <input type="submit" value="Guardar" class="btn btn-success" />
            </div>

        </form>

    </div>
</div>

<br />

<div>
    <a asp-action="Index" class="btn btn-secondary">
        Regresar Lista
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
